<https://palazzo.io/ontology/Climate/Ind/Narrative/PalazzoBronzino/2025-01-01> a plz-cl:WeatherNarrative ;
    plz-cl-nar:hasWeatherNarrativeStatement [ a plz-cl-nar:Statement ;
            plz-cl-nar:hasTemporalAdjective [ plz-cl-nar:hasAdjective <https://palazzo.io/ontology/Climate/NarrativeTerm/Temperature/Mild> ;
                    plz-cl-nar:hasTemporalExpression <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Afternoon>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Evening>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Morning>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Night> ] ;
            plz-cl-nar:isStatementOnWeatherPhenomenon plz-cl-nar:Temperature ],
        [ a plz-cl-nar:Statement ;
            plz-cl-nar:hasTemporalAdjective [ plz-cl-nar:hasAdjective <https://palazzo.io/ontology/Climate/NarrativeTerm/WIND/Moderate> ;
                    plz-cl-nar:hasTemporalExpression <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Afternoon>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Evening>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Morning>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Night> ] ;
            plz-cl-nar:isStatementOnWeatherPhenomenon plz-cl-nar:WIND ],
        [ a plz-cl-nar:Statement ;
            plz-cl-nar:hasTemporalAdjective [ plz-cl-nar:hasAdjective <https://palazzo.io/ontology/Climate/NarrativeTerm/Sky/Cloudy> ;
                    plz-cl-nar:hasTemporalExpression <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Afternoon>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Morning> ] ;
            plz-cl-nar:isStatementOnWeatherPhenomenon plz-cl-nar:Sky ],
        [ a plz-cl-nar:Statement ;
            plz-cl-nar:hasTemporalAdjective [ plz-cl-nar:hasAdjective <https://palazzo.io/ontology/Climate/NarrativeTerm/Rain/Showers> ;
                    plz-cl-nar:hasTemporalExpression <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Afternoon>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Evening>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Morning>,
                        <https://palazzo.io/ontology/Climate/NarrativeTerm/TemporalTerm/Night> ] ;
            plz-cl-nar:isStatementOnWeatherPhenomenon plz-cl-nar:Rain ] ;
    plz-cl:isRecordedAtDateTime "2025-01-01"^^xsd:date ;
    plz-cl:recordedAtLocale plz-cl-ind-loc:PalazzoBronzino .

